<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state: scale down and hold -->
    <item android:state_pressed="true">
        <set>
            <objectAnimator
                android:propertyName="scaleX"
                android:duration="100"
                android:valueTo="0.96"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="100"
                android:valueTo="0.96"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="100"
                android:valueTo="2dp"
                android:valueType="floatType" />
        </set>
    </item>
    <!-- Focused state: scale up slightly for preview -->
    <item android:state_focused="true">
        <set>
            <objectAnimator
                android:propertyName="scaleX"
                android:duration="100"
                android:valueTo="1.02"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="100"
                android:valueTo="1.02"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="100"
                android:valueTo="4dp"
                android:valueType="floatType" />
        </set>
    </item>
    <!-- Default state: return to normal with ease -->
    <item>
        <set>
            <objectAnimator
                android:propertyName="scaleX"
                android:duration="150"
                android:valueTo="1.0"
                android:valueType="floatType"
                android:interpolator="@android:interpolator/accelerate_decelerate" />
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="150"
                android:valueTo="1.0"
                android:valueType="floatType"
                android:interpolator="@android:interpolator/accelerate_decelerate" />
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="150"
                android:valueTo="0dp"
                android:valueType="floatType"
                android:interpolator="@android:interpolator/accelerate_decelerate" />
        </set>
    </item>
</selector>
