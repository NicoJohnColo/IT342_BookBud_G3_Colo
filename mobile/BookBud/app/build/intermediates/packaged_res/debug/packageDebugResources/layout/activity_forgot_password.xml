<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bb_background_light">

    <!-- Top bookshelf image -->
    <ImageView
        android:id="@+id/imageForgotHeader"
        android:layout_width="0dp"
        android:layout_height="260dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/forgot_password"
        android:src="@drawable/login_forget_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- White card with rounded top corners -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:background="@drawable/bg_forgot_card"
        app:layout_constraintTop_toBottomOf="@id/imageForgotHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="28dp">

            <!-- Forgot Password Title -->
            <TextView
                android:id="@+id/textForgotTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/forgot_password"
                android:textColor="@color/bb_orange"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Description -->
            <TextView
                android:id="@+id/textForgotDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/forgot_password_description"
                android:textColor="@color/bb_text_muted"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                app:layout_constraintTop_toBottomOf="@id/textForgotTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Email Label -->
            <TextView
                android:id="@+id/textEmailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/email_label"
                android:textColor="@color/bb_text_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/textForgotDescription"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Email Input -->
            <EditText
                android:id="@+id/editForgotEmail"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:hint="test1@gmail.com"
                android:textColorHint="@color/bb_text_muted"
                android:inputType="textEmailAddress"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/bb_text_dark"
                android:textSize="14sp"
                android:singleLine="true"
                app:layout_constraintTop_toBottomOf="@id/textEmailLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Send Button -->
            <Button
                android:id="@+id/buttonSendReset"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_primary_button"
                android:text="SEND  →"
                android:textColor="@color/bb_text_light"
                android:textSize="14sp"
                android:textStyle="bold"
                android:elevation="3dp"
                app:layout_constraintTop_toBottomOf="@id/editForgotEmail"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Back to Login row -->
            <LinearLayout
                android:id="@+id/layoutBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/buttonSendReset"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/textBackToLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/back_to_login"
                    android:textColor="@color/bb_text_muted"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/textSignIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/sign_in"
                    android:textColor="@color/bb_orange_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
