<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bb_background_light">

    <!-- Top bookshelf image -->
    <ImageView
        android:id="@+id/imageLoginHeader"
        android:layout_width="0dp"
        android:layout_height="260dp"
        android:scaleType="centerCrop"
        android:contentDescription="Bookshelf"
        android:src="@drawable/login_forget_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- White card bottom -->
    <ScrollView
        android:id="@+id/scrollLogin"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:background="@drawable/bg_forgot_card"
        app:layout_constraintTop_toBottomOf="@id/imageLoginHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="28dp">

            <!-- Login Title -->
            <TextView
                android:id="@+id/textLoginTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Login"
                android:textColor="@color/bb_text_dark"
                android:textSize="26sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Email -->
            <EditText
                android:id="@+id/editLoginEmail"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_input_field"
                android:hint="Enter Email Address"
                android:textColorHint="@color/bb_text_muted"
                android:inputType="textEmailAddress"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/bb_text_dark"
                android:textSize="14sp"
                android:singleLine="true"
                app:layout_constraintTop_toBottomOf="@id/textLoginTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Password -->
            <FrameLayout
                android:id="@+id/layoutLoginPassword"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                app:layout_constraintTop_toBottomOf="@id/editLoginEmail"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <EditText
                    android:id="@+id/editLoginPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_input_field"
                    android:hint="Enter Password"
                    android:textColorHint="@color/bb_text_muted"
                    android:inputType="textPassword"
                    android:paddingStart="16dp"
                    android:paddingEnd="52dp"
                    android:textColor="@color/bb_text_dark"
                    android:textSize="14sp"
                    android:singleLine="true" />

                <ImageView
                    android:id="@+id/toggleLoginPassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_eye_off"
                    android:contentDescription="Toggle password"
                    android:clickable="true"
                    android:focusable="true" />
            </FrameLayout>

            <!-- Forgot Password link -->
            <TextView
                android:id="@+id/textForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/forgot_password"
                android:textColor="@color/bb_orange_dark"
                android:textSize="13sp"
                app:layout_constraintTop_toBottomOf="@id/layoutLoginPassword"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressLogin"
                style="?android:attr/progressBarStyle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/bb_orange"
                android:visibility="gone"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/textForgotPassword"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Login Button -->
            <Button
                android:id="@+id/buttonLogin"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_primary_button"
                android:text="Login"
                android:textAllCaps="false"
                android:textColor="@color/bb_text_light"
                android:textSize="15sp"
                android:textStyle="bold"
                android:elevation="3dp"
                app:layout_constraintTop_toBottomOf="@id/progressLogin"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- No account row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="18dp"
                app:layout_constraintTop_toBottomOf="@id/buttonLogin"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_account_register"
                    android:textColor="@color/bb_text_muted"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/textNoAccount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Register"
                    android:textColor="@color/bb_text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
