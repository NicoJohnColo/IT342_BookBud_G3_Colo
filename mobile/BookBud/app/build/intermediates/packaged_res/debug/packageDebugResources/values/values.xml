    <style name="ButtonStyle.BookBud" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAppearance">@style/TextAppearance.BookBud.LabelLarge</item>
        <item name="android:textColor">@color/color_dark</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="rippleColor">@color/color_primary_light</item>
    </style>
    <style name="ButtonStyle.BookBud.Primary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:background">@color/color_primary</item>
        <item name="android:textAppearance">@style/TextAppearance.BookBud.LabelLarge</item>
        <item name="android:textColor">@color/color_white</item>
        <item name="cornerRadius">@dimen/radius_md</item>
    </style>
    <style name="ButtonStyle.BookBud.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAppearance">@style/TextAppearance.BookBud.LabelLarge</item>
        <item name="android:textColor">@color/color_primary</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="strokeColor">@color/color_primary</item>
        <item name="strokeWidth">2dp</item>
    </style>
    <style name="CardStyle.BookBud" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">@dimen/radius_md</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/color_white</item>
        <item name="strokeColor">@color/color_gray_200</item>
    </style>
    <style name="DividerStyle" parent="DividerStyle.BookBud"/>
    <style name="DividerStyle.BookBud">
        <item name="android:background">@color/color_gray_200</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_width">match_parent</item>
    </style>
    <style name="EditTextStyle.BookBud" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textAppearance">@style/TextAppearance.BookBud.BodyMedium</item>
        <item name="android:textColor">@color/color_dark</item>
        <item name="android:hint">@string/app_name</item>
        <item name="android:textColorHint">@color/color_gray_400</item>
    </style>
    <style name="TextAppearance.BookBud.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/color_dark</item>
    </style>
    <style name="TextAppearance.BookBud.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/color_dark</item>
    </style>
    <style name="Theme.BookBud" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bb_orange</item>
        <item name="colorPrimaryVariant">@color/bb_orange_dark</item>
        <item name="colorOnPrimary">@color/bb_text_light</item>
        <item name="android:windowBackground">@color/bb_card_white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
    <style name="Theme.BookBud.Splash" parent="Theme.BookBud">
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>